# ========== 用户数据库配置 ==========

# PostgreSQL 直连（数据库初始化使用）
USER_POSTGRESQL_URL=your-url

# Supabase SDK（应用运行时使用）
SUPABASE_URL=your-url
SUPABASE_SERVICE_ROLE_KEY=your-key

# ========== 分配记录数仓查询配置 ==========

# 查询提供方：mock / bigdata-mcp / sql-api
# 本地开发可用 mock；大圣部署支持大数据 MCP 时用 bigdata-mcp。
ALLOCATION_QUERY_PROVIDER=mock

# 大圣部署环境可调用的大数据 MCP HTTP 地址。
# 请求体按 MCP tool call 形式发送：
# { "toolName": "adhoc_submitQuery", "arguments": { "sql": "...", "engine": "Spark", "catalog": "hive_f04", "database": "dw_ads" } }
ALLOCATION_BIGDATA_MCP_URL=

# 大数据 MCP Token，仅服务端使用，不要加 NEXT_PUBLIC_。
ALLOCATION_BIGDATA_MCP_TOKEN=

# 大数据 MCP 查询等待秒数。
ALLOCATION_BIGDATA_MCP_TIMEOUT_SECONDS=60

# 可部署环境能访问的通用 SQL 执行服务地址。
# 未配置时，工作台会使用 app/api/allocation/mock-data.ts 中的 mock 数据。
ALLOCATION_SQL_API_URL=

# SQL 执行服务鉴权 token。如服务不需要鉴权，可留空。
ALLOCATION_SQL_API_TOKEN=

# SQL 查询超时时间，单位毫秒。
ALLOCATION_SQL_API_TIMEOUT_MS=30000

# SQL 查询失败时是否回退 mock 数据。
# 本地开发建议 true；生产接真数仓后建议 false。
ALLOCATION_USE_MOCK=true

# ========== 每日缓存配置 ==========
# 启用后，已刷新日期的用户查询直接读取 Supabase，不再实时跑 Spark。
ALLOCATION_CACHE_ENABLED=false

# 定时任务调用刷新接口时使用的密钥（请使用随机长字符串）。
ALLOCATION_CACHE_REFRESH_TOKEN=

# 缓存滚动保留天数。
ALLOCATION_CACHE_RETENTION_DAYS=90

# 单个渠道缓存刷新最多等待秒数；与HTTP调用的900秒上限配套。
ALLOCATION_CACHE_QUERY_TIMEOUT_SECONDS=600
